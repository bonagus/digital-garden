---
/**
 * PodcastLayout — Medium-style podcast/audiobook layout
 * Cover below meta + audio player
 */
import BaseLayout from './BaseLayout.astro';
import Backlinks from '../components/content/Backlinks.astro';
import RelatedContent from '../components/content/RelatedContent.astro';

interface Props {
  title: string;
  description?: string;
  startDate?: string;
  updated?: string;
  topics?: string[];
  growthStage?: 'seedling' | 'budding' | 'evergreen';
  author: string;
  cover?: string;
  duration?: string;
  audioUrl?: string;
  sourceUrl?: string;
  series?: string;
  contentId?: string;
}

const {
  title, description, startDate, updated, topics, growthStage,
  author, cover, duration, audioUrl, sourceUrl, series, contentId,
} = Astro.props;

const growthEmoji = { seedling: '🌱', budding: '🌿', evergreen: '🌳' };

function formatFullDate(date?: string): string {
  if (!date) return '';
  return new Date(date).toLocaleDateString('id-ID', {
    year: 'numeric', month: 'long', day: 'numeric',
  });
}
---

<BaseLayout title={title} description={description}>
  <article class="podcast-article">
    <!-- Header meta -->
    <header class="podcast-header">
      <div class="meta-top">
        <span class="content-type">Podcast / Audiobook</span>
        {growthStage && (
          <span class="growth-badge">
            <span>{growthEmoji[growthStage]}</span>
            {growthStage}
          </span>
        )}
      </div>

      {series && <p class="podcast-series">{series}</p>}
      <h1 class="podcast-title">{title}</h1>
      <p class="podcast-author">by {author}</p>

      {description && <p class="podcast-description">{description}</p>}

      <div class="podcast-meta">
        {duration && <span class="meta-item">⏱ {duration}</span>}
        {startDate && <span class="meta-item">Listened {formatFullDate(startDate)}</span>}
      </div>

      {/* Audio player */}
      {audioUrl && (
        <div class="audio-player">
          <audio controls preload="metadata" class="audio-element">
            <source src={audioUrl} />
            Browser Anda tidak mendukung audio player.
          </audio>
        </div>
      )}

      {/* Source link */}
      {sourceUrl && (
        <a href={sourceUrl} target="_blank" rel="noopener noreferrer" class="source-link">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4a.75.75 0 011.5 0v4A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h5a.75.75 0 010 1.5h-5z" clip-rule="evenodd" />
            <path fill-rule="evenodd" d="M6.194 12.753a.75.75 0 001.06.053L16.5 4.44v2.81a.75.75 0 001.5 0v-4.5a.75.75 0 00-.75-.75h-4.5a.75.75 0 000 1.5h2.553l-9.056 8.194a.75.75 0 00-.053 1.06z" clip-rule="evenodd" />
          </svg>
          Original Source
        </a>
      )}

      {topics && topics.length > 0 && (
        <div class="podcast-topics">
          {topics.map((topic) => (
            <a href={`/topics/${encodeURIComponent(topic.toLowerCase())}`} class="topic-pill">{topic}</a>
          ))}
        </div>
      )}
    </header>

    <!-- Cover below meta -->
    {cover && (
      <figure class="cover-figure">
        <img src={cover} alt={`Cover of ${title}`} class="podcast-cover" />
      </figure>
    )}

    <!-- Divider -->
    <hr class="content-divider" />

    <!-- Body -->
    <div class="prose">
      <slot />
    </div>

    {contentId && topics && topics.length > 0 && <RelatedContent contentId={contentId} topics={topics} />}
    {contentId && <Backlinks contentId={contentId} />}
  </article>
</BaseLayout>

<style>
  .podcast-article {
    max-width: var(--width-content);
    margin: 0 auto;
    padding: 0 2rem 4rem;
  }

  .podcast-header {
    margin-top: 3rem;
    margin-bottom: 0;
  }

  .meta-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .content-type {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
  }

  .growth-badge {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .podcast-series {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--text-muted);
    margin: 0 0 0.5rem 0;
  }

  /* Medium-style large title */
  .podcast-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 700;
    color: var(--text-heading);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem 0;
  }

  .podcast-author {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 2vw, 1.125rem);
    font-weight: 400;
    color: var(--text-muted);
    margin: 0 0 1rem 0;
    font-style: italic;
  }

  /* Medium-style description */
  .podcast-description {
    font-family: var(--font-sans);
    font-size: clamp(1.125rem, 2.5vw, 1.25rem);
    color: var(--text-body);
    line-height: 1.5;
    margin: 0 0 1.25rem 0;
  }

  .podcast-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .meta-item {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .audio-player {
    margin-bottom: 0.75rem;
  }

  .audio-element {
    width: 100%;
    max-width: 500px;
    height: 40px;
    border-radius: var(--radius-base);
  }

  .source-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 0.4rem 0.75rem;
    text-decoration: none;
    margin-bottom: 0.75rem;
    transition: all 0.2s ease-in-out;
  }

  .source-link:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .podcast-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.5rem;
  }

  .topic-pill {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--text-muted);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 3rem;
    padding: 0.2rem 0.75rem;
    text-decoration: none;
    transition: all 0.2s ease-in-out;
  }

  .topic-pill:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Cover below meta */
  .cover-figure {
    margin: 2.5rem auto;
    max-width: 300px;
  }

  .podcast-cover {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-base);
    box-shadow: var(--shadow-md);
  }

  /* Divider */
  .content-divider {
    border: none;
    border-top: 1px solid var(--border-color);
    margin: 2.5rem 0;
  }

  .cover-figure + .content-divider {
    margin-top: 0;
  }
</style>
