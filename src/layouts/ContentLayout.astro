---
import BaseLayout from './BaseLayout.astro';
import Backlinks from '../components/content/Backlinks.astro';
import RelatedContent from '../components/content/RelatedContent.astro';

interface Props {
  title: string;
  description?: string;
  type?: string;
  startDate?: string;
  updated?: string;
  topics?: string[];
  growthStage?: 'seedling' | 'budding' | 'evergreen';
  cover?: string;
  contentId?: string;
}

const { title, description, type, startDate, updated, topics, growthStage, cover, contentId } = Astro.props;

const growthEmoji = {
  seedling: '🌱',
  budding: '🌿',
  evergreen: '🌳',
};

function formatFullDate(date?: string): string {
  if (!date) return '';
  return new Date(date).toLocaleDateString('id-ID', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title={title} description={description}>
  <article class="content-article">
    <!-- Header meta -->
    <header class="content-header">
      <div class="content-meta-top">
        {type && <span class="content-type">{type}</span>}
        {growthStage && (
          <span class="growth-badge">
            <span class="growth-emoji">{growthEmoji[growthStage]}</span>
            {growthStage}
          </span>
        )}
      </div>

      <h1 class="content-title">{title}</h1>

      {description && (
        <p class="content-description">{description}</p>
      )}

      <div class="content-meta-bottom">
        {startDate && (
          <span class="meta-item">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" class="meta-icon">
              <path fill-rule="evenodd" d="M5.75 2a.75.75 0 01.75.75V4h7V2.75a.75.75 0 011.5 0V4h.25A2.75 2.75 0 0118 6.75v8.5A2.75 2.75 0 0115.25 18H4.75A2.75 2.75 0 012 15.25v-8.5A2.75 2.75 0 014.75 4H5V2.75A.75.75 0 015.75 2z" clip-rule="evenodd" />
            </svg>
            Planted {formatFullDate(startDate)}
          </span>
        )}
        {updated && updated !== startDate && (
          <span class="meta-item">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" class="meta-icon">
              <path fill-rule="evenodd" d="M15.312 11.424a5.5 5.5 0 01-9.201 2.466l-.312-.311h2.433a.75.75 0 000-1.5H3.989a.75.75 0 00-.75.75v4.242a.75.75 0 001.5 0v-2.43l.31.31a7 7 0 0011.712-3.138.75.75 0 00-1.449-.39zm1.23-3.723a.75.75 0 00.219-.53V2.929a.75.75 0 00-1.5 0V5.36l-.31-.31A7 7 0 003.239 8.188a.75.75 0 101.448.389A5.5 5.5 0 0113.89 6.11l.311.31h-2.432a.75.75 0 000 1.5h4.243a.75.75 0 00.53-.219z" clip-rule="evenodd" />
            </svg>
            Updated {formatFullDate(updated)}
          </span>
        )}
      </div>

      {topics && topics.length > 0 && (
        <div class="content-topics">
          {topics.map((topic) => (
            <a href={`/topics/${encodeURIComponent(topic.toLowerCase())}`} class="topic-pill">{topic}</a>
          ))}
        </div>
      )}
    </header>

    <!-- Cover image (full-width) -->
    {cover && (
      <figure class="cover-figure">
        <img src={cover} alt={`Cover ${title}`} class="cover-image" />
      </figure>
    )}

    <!-- Divider -->
    <hr class="content-divider" />

    <!-- Body -->
    <div class="prose">
      <slot />
    </div>

    <!-- Related Content -->
    {contentId && topics && topics.length > 0 && <RelatedContent contentId={contentId} topics={topics} />}

    <!-- Backlinks -->
    {contentId && <Backlinks contentId={contentId} />}
  </article>
</BaseLayout>

<style>
  .content-article {
    max-width: var(--width-content);
    margin: 0 auto;
    padding: 0 2rem 4rem;
  }

  .content-header {
    margin-top: 3rem;
    margin-bottom: 0;
  }

  .content-meta-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .content-type {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
  }

  .growth-badge {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    text-transform: capitalize;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .growth-emoji {
    font-size: 0.875rem;
  }

  /* Medium-style large title */
  .content-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 700;
    color: var(--text-heading);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0 0 1rem 0;
  }

  /* Medium-style subtitle */
  .content-description {
    font-family: var(--font-sans);
    font-size: clamp(1.125rem, 2.5vw, 1.375rem);
    font-weight: 400;
    color: var(--text-muted);
    line-height: 1.4;
    margin: 0 0 1.5rem 0;
  }

  .content-meta-bottom {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .meta-icon {
    color: var(--text-faint);
  }

  .content-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .topic-pill {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--text-muted);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 3rem;
    padding: 0.2rem 0.75rem;
    text-decoration: none;
    transition: all 0.2s ease-in-out;
  }

  .topic-pill:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Cover — full width of content column, flexible height */
  .cover-figure {
    margin: 2.5rem 0;
  }

  .cover-image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-base);
  }

  /* Divider before body */
  .content-divider {
    border: none;
    border-top: 1px solid var(--border-color);
    margin: 2.5rem 0;
  }

  /* When there's a cover, the figure already provides spacing — tighten the divider gap above it */
  .cover-figure + .content-divider {
    margin-top: 0;
  }
</style>
