---
import BaseLayout from './BaseLayout.astro';
import Backlinks from '../components/content/Backlinks.astro';

interface Props {
  title: string;
  description?: string;
  type?: string;
  startDate?: string;
  updated?: string;
  topics?: string[];
  growthStage?: 'seedling' | 'budding' | 'evergreen';
  contentId?: string;
}

const { title, description, type, startDate, updated, topics, growthStage, contentId } = Astro.props;

const growthEmoji = {
  seedling: '🌱',
  budding: '🌿',
  evergreen: '🌳',
};

function formatFullDate(date?: string): string {
  if (!date) return '';
  return new Date(date).toLocaleDateString('id-ID', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title={title} description={description}>
  <article class="content-article">
    <!-- Content Header -->
    <header class="content-header">
      <div class="content-meta-top">
        {type && <span class="content-type">{type}</span>}
        {growthStage && (
          <span class="growth-badge">
            <span class="growth-emoji">{growthEmoji[growthStage]}</span>
            {growthStage}
          </span>
        )}
      </div>

      <h1 class="content-title">{title}</h1>

      {description && (
        <p class="content-description">{description}</p>
      )}

      <div class="content-meta-bottom">
        {startDate && (
          <span class="meta-item">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" class="meta-icon">
              <path fill-rule="evenodd" d="M5.75 2a.75.75 0 01.75.75V4h7V2.75a.75.75 0 011.5 0V4h.25A2.75 2.75 0 0118 6.75v8.5A2.75 2.75 0 0115.25 18H4.75A2.75 2.75 0 012 15.25v-8.5A2.75 2.75 0 014.75 4H5V2.75A.75.75 0 015.75 2z" clip-rule="evenodd" />
            </svg>
            Planted {formatFullDate(startDate)}
          </span>
        )}
        {updated && updated !== startDate && (
          <span class="meta-item">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" class="meta-icon">
              <path fill-rule="evenodd" d="M15.312 11.424a5.5 5.5 0 01-9.201 2.466l-.312-.311h2.433a.75.75 0 000-1.5H3.989a.75.75 0 00-.75.75v4.242a.75.75 0 001.5 0v-2.43l.31.31a7 7 0 0011.712-3.138.75.75 0 00-1.449-.39zm1.23-3.723a.75.75 0 00.219-.53V2.929a.75.75 0 00-1.5 0V5.36l-.31-.31A7 7 0 003.239 8.188a.75.75 0 101.448.389A5.5 5.5 0 0113.89 6.11l.311.31h-2.432a.75.75 0 000 1.5h4.243a.75.75 0 00.53-.219z" clip-rule="evenodd" />
            </svg>
            Updated {formatFullDate(updated)}
          </span>
        )}
      </div>

      {topics && topics.length > 0 && (
        <div class="content-topics">
          {topics.map((topic) => (
            <span class="topic-pill">{topic}</span>
          ))}
        </div>
      )}
    </header>

    <!-- Prose Content -->
    <div class="prose">
      <slot />
    </div>

    <!-- Backlinks -->
    {contentId && <Backlinks contentId={contentId} />}
  </article>
</BaseLayout>

<style>
  .content-article {
    max-width: var(--width-content);
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  .content-header {
    margin-top: 2.5rem;
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-tinted-cream);
  }

  .content-meta-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .content-type {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-sea-blue);
  }

  .growth-badge {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    text-transform: capitalize;
    color: var(--color-gray-500);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .growth-emoji {
    font-size: 0.875rem;
  }

  .content-title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 700;
    color: var(--color-gray-800);
    line-height: 1.2;
    margin: 0 0 0.75rem 0;
  }

  .content-description {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 300;
    color: var(--color-gray-600);
    line-height: 1.5;
    margin: 0 0 1rem 0;
  }

  .content-meta-bottom {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-gray-500);
  }

  .meta-icon {
    color: var(--color-gray-400);
  }

  .content-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .topic-pill {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-gray-600);
    background: var(--color-light-cream);
    border: 1px solid var(--color-tinted-cream);
    border-radius: 3rem;
    padding: 0.2rem 0.75rem;
    transition: all 0.2s ease-in-out;
  }

  .topic-pill:hover {
    border-color: var(--color-sea-blue);
    color: var(--color-crimson);
  }
</style>
