---
/**
 * ProjectLayout — case study layout for project detail pages
 * Shows tech stack badges, status, repo/demo links, and backlinks
 */
import BaseLayout from './BaseLayout.astro';
import Backlinks from '../components/content/Backlinks.astro';
import RelatedContent from '../components/content/RelatedContent.astro';

interface Props {
  title: string;
  description?: string;
  startDate?: string;
  updated?: string;
  topics?: string[];
  growthStage?: 'seedling' | 'budding' | 'evergreen';
  status?: 'active' | 'completed' | 'archived' | 'paused';
  techStack?: string[];
  repoUrl?: string;
  demoUrl?: string;
  contentId?: string;
}

const {
  title, description, startDate, updated, topics,
  growthStage, status, techStack, repoUrl, demoUrl, contentId,
} = Astro.props;

const growthEmoji = { seedling: '🌱', budding: '🌿', evergreen: '🌳' };
const statusLabel: Record<string, { text: string; color: string }> = {
  active: { text: 'Active', color: 'var(--color-evergreen)' },
  completed: { text: 'Completed', color: 'var(--accent)' },
  archived: { text: 'Archived', color: 'var(--text-faint)' },
  paused: { text: 'Paused', color: 'var(--color-budding)' },
};

function formatFullDate(date?: string): string {
  if (!date) return '';
  return new Date(date).toLocaleDateString('id-ID', {
    year: 'numeric', month: 'long', day: 'numeric',
  });
}

const statusInfo = status ? statusLabel[status] : null;
---

<BaseLayout title={title} description={description}>
  <article class="project-article">
    <header class="project-header">
      <div class="project-meta-top">
        <span class="project-type">Project</span>
        {statusInfo && (
          <span class="status-badge" style={`--status-color: ${statusInfo.color}`}>
            <span class="status-dot"></span>
            {statusInfo.text}
          </span>
        )}
        {growthStage && (
          <span class="growth-badge">
            <span class="growth-emoji">{growthEmoji[growthStage]}</span>
            {growthStage}
          </span>
        )}
      </div>

      <h1 class="project-title">{title}</h1>

      {description && <p class="project-description">{description}</p>}

      {/* Tech Stack Badges */}
      {techStack && techStack.length > 0 && (
        <div class="tech-stack">
          {techStack.map((tech) => (
            <span class="tech-badge">{tech}</span>
          ))}
        </div>
      )}

      {/* Action Links */}
      {(repoUrl || demoUrl) && (
        <div class="project-links">
          {repoUrl && (
            <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="project-link repo-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              Source Code
            </a>
          )}
          {demoUrl && (
            <a href={demoUrl} target="_blank" rel="noopener noreferrer" class="project-link demo-link">
              <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4a.75.75 0 011.5 0v4A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h5a.75.75 0 010 1.5h-5z" clip-rule="evenodd" />
                <path fill-rule="evenodd" d="M6.194 12.753a.75.75 0 001.06.053L16.5 4.44v2.81a.75.75 0 001.5 0v-4.5a.75.75 0 00-.75-.75h-4.5a.75.75 0 000 1.5h2.553l-9.056 8.194a.75.75 0 00-.053 1.06z" clip-rule="evenodd" />
              </svg>
              Live Demo
            </a>
          )}
        </div>
      )}

      <div class="project-meta-bottom">
        {startDate && (
          <span class="meta-item">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" class="meta-icon">
              <path fill-rule="evenodd" d="M5.75 2a.75.75 0 01.75.75V4h7V2.75a.75.75 0 011.5 0V4h.25A2.75 2.75 0 0118 6.75v8.5A2.75 2.75 0 0115.25 18H4.75A2.75 2.75 0 012 15.25v-8.5A2.75 2.75 0 014.75 4H5V2.75A.75.75 0 015.75 2z" clip-rule="evenodd" />
            </svg>
            Started {formatFullDate(startDate)}
          </span>
        )}
        {updated && updated !== startDate && (
          <span class="meta-item">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" class="meta-icon">
              <path fill-rule="evenodd" d="M15.312 11.424a5.5 5.5 0 01-9.201 2.466l-.312-.311h2.433a.75.75 0 000-1.5H3.989a.75.75 0 00-.75.75v4.242a.75.75 0 001.5 0v-2.43l.31.31a7 7 0 0011.712-3.138.75.75 0 00-1.449-.39zm1.23-3.723a.75.75 0 00.219-.53V2.929a.75.75 0 00-1.5 0V5.36l-.31-.31A7 7 0 003.239 8.188a.75.75 0 101.448.389A5.5 5.5 0 0113.89 6.11l.311.31h-2.432a.75.75 0 000 1.5h4.243a.75.75 0 00.53-.219z" clip-rule="evenodd" />
            </svg>
            Updated {formatFullDate(updated)}
          </span>
        )}
      </div>

      {topics && topics.length > 0 && (
        <div class="project-topics">
          {topics.map((topic) => (
            <a href={`/topics/${encodeURIComponent(topic.toLowerCase())}`} class="topic-pill">{topic}</a>
          ))}
        </div>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    <!-- Related Content -->
    {contentId && topics && topics.length > 0 && <RelatedContent contentId={contentId} topics={topics} />}

    {contentId && <Backlinks contentId={contentId} />}
  </article>
</BaseLayout>

<style>
  .project-article {
    max-width: var(--width-content);
    margin: 0 auto;
    padding: 0 2rem 4rem;
  }

  .project-header {
    margin-top: 2.5rem;
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-color);
  }

  .project-meta-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .project-type {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--status-color);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 3rem;
    padding: 0.15rem 0.625rem;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--status-color);
  }

  .growth-badge {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    text-transform: capitalize;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .growth-emoji { font-size: 0.875rem; }

  .project-title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 700;
    color: var(--text-heading);
    line-height: 1.2;
    margin: 0 0 0.75rem 0;
  }

  .project-description {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 400;
    color: var(--text-body);
    line-height: 1.5;
    margin: 0 0 1rem 0;
  }

  /* Tech Stack */
  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 1rem;
  }

  .tech-badge {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 400;
    color: var(--accent);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 0.2rem 0.5rem;
  }

  /* Action Links */
  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-base);
    border: 1px solid var(--border-color);
    text-decoration: none;
    transition: all 0.2s ease-in-out;
    color: var(--text-body);
    background: var(--bg-secondary);
  }

  .project-link:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .project-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .project-meta-bottom {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .meta-icon { color: var(--text-faint); }

  .project-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .topic-pill {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--text-muted);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 3rem;
    padding: 0.2rem 0.75rem;
    text-decoration: none;
    transition: all 0.2s ease-in-out;
  }

  .topic-pill:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>
