---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/content/ContentCard.astro';
import { getPublishedNotes } from '../lib/content';

const notes = await getPublishedNotes();
---

<BaseLayout title="Notes" description="Catatan pendek, learning notes, dan ide-ide kecil.">
  <div class="listing-wrapper">
    <header class="listing-header">
      <h1 class="listing-title">Notes</h1>
      <p class="listing-description">
        Catatan pendek tentang hal-hal yang sedang saya pelajari. Belum matang, tapi itulah intinya.
      </p>
    </header>

    <div class="listing-grid">
      {notes.map((note) => (
        <ContentCard
          title={note.data.title}
          description={note.data.description}
          href={`/${note.id}`}
          type="note"
          startDate={note.data.startDate}
          topics={note.data.topics}
          growthStage={note.data.growthStage}
          cover={note.data.cover}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .listing-wrapper {
    max-width: var(--width-wide);
    margin: 0 auto;
    padding: 0 2rem 4rem;
  }

  .listing-header {
    margin-top: 2.5rem;
    margin-bottom: 2rem;
  }

  .listing-title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.5rem;
  }

  .listing-description {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 400;
    color: var(--text-body);
    max-width: 600px;
    line-height: 1.6;
  }

  .listing-grid {
    columns: 3 18rem;
    column-gap: 0.75rem;
  }

  .listing-grid > * {
    break-inside: avoid;
    margin-bottom: 0.75rem;
  }

  @media (max-width: 640px) {
    .listing-grid { columns: 1; }
  }
</style>
