---
export const prerender = true;
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BookLayout from '../layouts/BookLayout.astro';
import PodcastLayout from '../layouts/PodcastLayout.astro';
import ContentLayout from '../layouts/ContentLayout.astro';
import ProjectLayout from '../layouts/ProjectLayout.astro';

export async function getStaticPaths() {
  const collections = ['notes', 'essays', 'books', 'podcasts', 'projects', 'experiments', 'timeline'] as const;
  const paths = [];

  for (const collectionName of collections) {
    const entries = await getCollection(collectionName);
    for (const entry of entries) {
      paths.push({
        params: { slug: entry.id },
        props: { entry, collection: collectionName },
      });
    }
  }

  return paths;
}

const { entry, collection } = Astro.props;
const { Content } = await render(entry);

const { title, description, startDate, updated, topics, growthStage } = entry.data;
const type = 'type' in entry.data ? entry.data.type : undefined;
const dateStr = typeof startDate === 'string' ? startDate : startDate?.toISOString();
const updatedStr = typeof updated === 'string' ? updated : updated?.toISOString();
---

{collection === 'projects' ? (
  <ProjectLayout
    title={title}
    description={description}
    startDate={dateStr}
    updated={updatedStr}
    topics={topics}
    growthStage={growthStage}
    status={'status' in entry.data ? entry.data.status : undefined}
    techStack={'techStack' in entry.data ? entry.data.techStack : undefined}
    repoUrl={'repoUrl' in entry.data ? entry.data.repoUrl : undefined}
    demoUrl={'demoUrl' in entry.data ? entry.data.demoUrl : undefined}
    cover={'cover' in entry.data ? entry.data.cover : undefined}
    contentId={entry.id}
  >
    <Content />
  </ProjectLayout>
) : collection === 'books' ? (
  <BookLayout
    title={title}
    description={description}
    startDate={dateStr}
    updated={updatedStr}
    topics={topics}
    growthStage={growthStage}
    author={'author' in entry.data ? entry.data.author : ''}
    cover={'cover' in entry.data ? entry.data.cover : undefined}
    rating={'rating' in entry.data ? entry.data.rating : undefined}
    year={'year' in entry.data ? entry.data.year : undefined}
    pages={'pages' in entry.data ? entry.data.pages : undefined}
    status={'status' in entry.data ? entry.data.status : undefined}
    sourceUrl={'sourceUrl' in entry.data ? entry.data.sourceUrl : undefined}
    contentId={entry.id}
  >
    <Content />
  </BookLayout>
) : collection === 'podcasts' ? (
  <PodcastLayout
    title={title}
    description={description}
    startDate={dateStr}
    updated={updatedStr}
    topics={topics}
    growthStage={growthStage}
    author={'author' in entry.data ? entry.data.author : ''}
    cover={'cover' in entry.data ? entry.data.cover : undefined}
    duration={'duration' in entry.data ? entry.data.duration : undefined}
    audioUrl={'audioUrl' in entry.data ? entry.data.audioUrl : undefined}
    sourceUrl={'sourceUrl' in entry.data ? entry.data.sourceUrl : undefined}
    series={'series' in entry.data ? entry.data.series : undefined}
    contentId={entry.id}
  >
    <Content />
  </PodcastLayout>
) : (
  <ContentLayout
    title={title}
    description={description}
    type={type}
    startDate={dateStr}
    updated={updatedStr}
    topics={topics}
    growthStage={growthStage}
    cover={'cover' in entry.data ? entry.data.cover : undefined}
    contentId={entry.id}
  >
    <Content />
  </ContentLayout>
)}
