---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedTimeline, formatDate } from '../lib/content';
import { getTimelinePageSettings } from '../lib/settings';

const entries = await getPublishedTimeline();
const page = await getTimelinePageSettings();

const categoryMeta: Record<string, { icon: string; label: string }> = {
  now: { icon: '📍', label: 'Now' },
  milestone: { icon: '🎯', label: 'Milestone' },
  update: { icon: '📝', label: 'Update' },
  life: { icon: '🌤', label: 'Life' },
};

// Group by year (entries already sorted newest-first)
const groups = new Map<number, typeof entries>();
for (const entry of entries) {
  const year = new Date(entry.data.startDate).getFullYear();
  if (!groups.has(year)) groups.set(year, []);
  groups.get(year)!.push(entry);
}
const years = Array.from(groups.keys()).sort((a, b) => b - a);
---

<BaseLayout title={page.title} description={page.description}>
  <div class="timeline-wrapper">
    <header class="timeline-header">
      <h1 class="timeline-title">{page.title}</h1>
      <p class="timeline-description">{page.description}</p>
    </header>

    {entries.length === 0 ? (
      <p class="empty-state">Belum ada update. Tambahkan lewat CMS di <code>/keystatic</code> → Timeline.</p>
    ) : (
      <div class="timeline">
        {years.map((year) => (
          <section class="year-group">
            <h2 class="year-label">{year}</h2>
            <ol class="entry-list">
              {groups.get(year)!.map((entry) => {
                const meta = categoryMeta[entry.data.category] ?? categoryMeta.update;
                return (
                  <li class="entry">
                    <span class="entry-dot" title={meta.label}>{meta.icon}</span>
                    <div class="entry-body">
                      <time class="entry-date">{formatDate(entry.data.startDate)}</time>
                      <h3 class="entry-title">
                        <a href={`/${entry.id}`}>{entry.data.title}</a>
                      </h3>
                      <p class="entry-desc">{entry.data.description}</p>
                      {entry.data.topics.length > 0 && (
                        <div class="entry-topics">
                          {entry.data.topics.slice(0, 4).map((topic) => (
                            <a href={`/topics/${encodeURIComponent(topic.toLowerCase())}`} class="entry-topic">{topic}</a>
                          ))}
                        </div>
                      )}
                    </div>
                  </li>
                );
              })}
            </ol>
          </section>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .timeline-wrapper {
    max-width: var(--width-content);
    margin: 0 auto;
    padding: 0 2rem 4rem;
  }

  .timeline-header {
    margin-top: 2.5rem;
    margin-bottom: 2.5rem;
  }

  .timeline-title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.5rem;
  }

  .timeline-description {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--text-body);
    line-height: 1.6;
    max-width: 600px;
  }

  .inline-link {
    color: var(--accent);
    text-decoration: none;
  }

  .inline-link:hover {
    text-decoration: underline;
  }

  .empty-state {
    font-family: var(--font-sans);
    color: var(--text-muted);
  }

  .empty-state code {
    font-family: var(--font-mono, monospace);
    background: var(--bg-secondary);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
  }

  .year-group {
    margin-bottom: 2.5rem;
  }

  .year-label {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .entry-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 2px solid var(--border-color);
  }

  .entry {
    position: relative;
    display: block;
    padding: 0 0 1.75rem 1.75rem;
  }

  .entry:last-child {
    padding-bottom: 0;
  }

  .entry-dot {
    position: absolute;
    left: -0.85rem;
    top: 0;
    width: 1.6rem;
    height: 1.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 50%;
  }

  .entry-date {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  .entry-title {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.4;
    margin: 0.125rem 0 0.375rem 0;
  }

  .entry-title a {
    color: var(--text-heading);
    text-decoration: none;
    transition: color 0.2s ease-in-out;
  }

  .entry-title a:hover {
    color: var(--accent);
  }

  .entry-desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--text-body);
    line-height: 1.6;
    margin: 0 0 0.5rem 0;
  }

  .entry-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .entry-topic {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    color: var(--text-muted);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 3rem;
    padding: 0.125rem 0.5rem;
    text-decoration: none;
    transition: all 0.2s ease-in-out;
  }

  .entry-topic:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>
