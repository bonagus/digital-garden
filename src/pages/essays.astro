---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/content/ContentCard.astro';
import { getPublishedEssays } from '../lib/content';

const essays = await getPublishedEssays();
---

<BaseLayout title="Essays" description="Tulisan panjang, opini, dan eksplorasi mendalam.">
  <div class="listing-wrapper">
    <header class="listing-header">
      <h1 class="listing-title">Essays</h1>
      <p class="listing-description">
        Tulisan panjang yang sudah lebih matang. Opini, analisis, dan eksplorasi mendalam tentang topik yang saya minati.
      </p>
    </header>

    <div class="listing-grid">
      {essays.map((essay) => (
        <ContentCard
          title={essay.data.title}
          description={essay.data.description}
          href={`/${essay.id}`}
          type="essay"
          startDate={essay.data.startDate}
          topics={essay.data.topics}
          growthStage={essay.data.growthStage}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .listing-wrapper {
    max-width: var(--width-wide);
    margin: 0 auto;
    padding: 0 2rem 4rem;
  }

  .listing-header {
    margin-top: 2.5rem;
    margin-bottom: 2rem;
  }

  .listing-title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.5rem;
  }

  .listing-description {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 400;
    color: var(--text-body);
    max-width: 600px;
    line-height: 1.6;
  }

  .listing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 0.75rem;
  }
</style>
