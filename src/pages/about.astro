---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAboutSettings, getSocialLinks } from '../lib/settings';
import { getPublishedTimeline, formatDate } from '../lib/content';

const about = await getAboutSettings();
const socialLinks = await getSocialLinks();
const timelineEntries = await getPublishedTimeline();

const categoryMeta: Record<string, { icon: string; label: string }> = {
  now: { icon: '📍', label: 'Now' },
  milestone: { icon: '🎯', label: 'Milestone' },
  update: { icon: '📝', label: 'Update' },
  life: { icon: '🌤', label: 'Life' },
};
---

<BaseLayout title="About" description={about.description}>
  <div class="about-wrapper">

    {/* ── Atas: foto (kiri) + header (kanan) ── */}
    <div class:list={['about-top', { 'has-photo': Boolean(about.photo) }]}>
      {about.photo && (
        <div class="about-photo-col">
          <div class="about-photo-wrap">
            <img src={about.photo} alt={`Foto ${about.titleActive}`} class="about-photo" />
          </div>
        </div>
      )}

      <header class="about-header-col">
        <h1 class="about-title">
          <strong>{about.titleActive}</strong> {about.titleRest}
        </h1>
        <p class="about-bio">{about.description}</p>

        {socialLinks.length > 0 && (
          <div class="about-socials">
            {socialLinks.map((link) => (
              <a
                href={link.href}
                class="about-social-link"
                target={link.key === 'email' ? undefined : '_blank'}
                rel="noopener noreferrer"
              >
                {link.label}
              </a>
            ))}
          </div>
        )}
      </header>
    </div>

    {/* ── Divider ── */}
    {about.experiences.length > 0 && <hr class="about-divider" />}

    {/* ── Bawah: pengalaman (kiri) + timeline (kanan) ── */}
    {about.experiences.length > 0 && (
      <div class="about-bottom">
        <section class="experience-section">
          <h2 class="section-title">Pengalaman</h2>
          <ol class="experience-list">
            {about.experiences.map((exp) => (
              <li class="experience-item">
                <div class="experience-period">{exp.period}</div>
                <div class="experience-body">
                  <h3 class="experience-role">
                    {exp.role}
                    {exp.company && (
                      <span class="experience-company">
                        {' · '}
                        {exp.url ? (
                          <a href={exp.url} target="_blank" rel="noopener noreferrer">{exp.company}</a>
                        ) : (
                          exp.company
                        )}
                      </span>
                    )}
                  </h3>
                  {exp.summary && <p class="experience-summary">{exp.summary}</p>}
                </div>
              </li>
            ))}
          </ol>
        </section>

        {timelineEntries.length > 0 && (
          <aside class="timeline-aside">
            <h2 class="section-title">Timeline</h2>
            <ol class="timeline-list">
              {timelineEntries.slice(0, 8).map((entry) => {
                const meta = categoryMeta[entry.data.category] ?? categoryMeta.update;
                return (
                  <li class="timeline-item">
                    <span class="timeline-dot" title={meta.label}>{meta.icon}</span>
                    <div class="timeline-body">
                      <time class="timeline-date">{formatDate(entry.data.startDate)}</time>
                      <h3 class="timeline-title-item">
                        <a href={`/${entry.id}`}>{entry.data.title}</a>
                      </h3>
                      {entry.data.description && (
                        <p class="timeline-desc">{entry.data.description}</p>
                      )}
                    </div>
                  </li>
                );
              })}
            </ol>
            {timelineEntries.length > 8 && (
              <a href="/timeline" class="timeline-more">Lihat semua →</a>
            )}
          </aside>
        )}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .about-wrapper {
    max-width: var(--width-wide);
    margin: 0 auto;
    padding: 0 2rem 4rem;
  }

  /* ── Atas: foto + header ── */
  .about-top {
    margin-top: 2.5rem;
    margin-bottom: 2.5rem;
  }

  .about-top.has-photo {
    display: grid;
    grid-template-columns: minmax(13rem, 0.75fr) minmax(0, 1.25fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  .about-photo-wrap {
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--radius-base);
    background: var(--bg-secondary);
  }

  .about-photo {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-title {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.3;
    color: var(--text-heading);
    margin-bottom: 1rem;
  }

  .about-title strong {
    font-weight: 700;
    color: var(--accent);
  }

  .about-bio {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    color: var(--text-body);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .about-socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .about-social-link {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-body);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 3rem;
    padding: 0.375rem 1rem;
    text-decoration: none;
    transition: all 0.2s ease-in-out;
  }

  .about-social-link:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ── Divider ── */
  .about-divider {
    border: none;
    border-top: 1px solid var(--border-color);
    margin: 0 0 2.5rem 0;
  }

  /* ── Bawah: experience (kiri) + timeline (kanan) ── */
  .about-bottom {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  .section-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 1.5rem;
  }

  /* Experience */
  .experience-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 2px solid var(--border-color);
  }

  .experience-item {
    position: relative;
    padding: 0 0 2rem 1.75rem;
  }

  .experience-item::before {
    content: '';
    position: absolute;
    left: -7px;
    top: 6px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent);
    border: 2px solid var(--bg-primary);
  }

  .experience-item:last-child {
    padding-bottom: 0;
  }

  .experience-period {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }

  .experience-role {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-heading);
    margin: 0 0 0.375rem 0;
    line-height: 1.4;
  }

  .experience-company {
    font-weight: 400;
    color: var(--text-body);
  }

  .experience-company a {
    color: var(--accent);
    text-decoration: none;
  }

  .experience-company a:hover {
    text-decoration: underline;
  }

  .experience-summary {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--text-body);
    line-height: 1.6;
    margin: 0;
  }

  /* Timeline aside */
  .timeline-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 2px solid var(--border-color);
  }

  .timeline-item {
    position: relative;
    padding: 0 0 1.5rem 1.75rem;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: -0.825rem;
    top: 0;
    width: 1.5rem;
    height: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 50%;
  }

  .timeline-date {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    display: block;
    margin-bottom: 0.125rem;
  }

  .timeline-title-item {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
    margin: 0 0 0.25rem 0;
  }

  .timeline-title-item a {
    color: var(--text-heading);
    text-decoration: none;
    transition: color 0.2s ease-in-out;
  }

  .timeline-title-item a:hover {
    color: var(--accent);
  }

  .timeline-desc {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--text-body);
    line-height: 1.5;
    margin: 0;
  }

  .timeline-more {
    display: inline-block;
    margin-top: 1rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
  }

  .timeline-more:hover {
    text-decoration: underline;
  }

  /* Responsive */
  @media (max-width: 720px) {
    .about-wrapper {
      padding-inline: 1.25rem;
    }

    .about-top.has-photo {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .about-photo-wrap {
      max-width: 22rem;
    }

    .about-bottom {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
