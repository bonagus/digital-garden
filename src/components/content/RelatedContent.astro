---
/**
 * RelatedContent — shows related entries based on shared topics
 */
import { getRelatedContent } from '../../lib/content';

interface Props {
  contentId: string;
  topics: string[];
}

const { contentId, topics } = Astro.props;
const related = await getRelatedContent(contentId, topics);

const typeLabel: Record<string, string> = {
  note: 'Note', essay: 'Essay', project: 'Project', experiment: 'Experiment',
};
---

{related.length > 0 && (
  <aside class="related-section">
    <h2 class="related-heading">Related</h2>
    <div class="related-grid">
      {related.map((entry) => {
        const entryType = 'type' in entry.data ? entry.data.type : 'note';
        return (
          <a href={`/${entry.id}/`} class="related-card">
            <span class="related-type">{typeLabel[entryType as string] || entryType}</span>
            <span class="related-title">{entry.data.title}</span>
            <span class="related-desc">{entry.data.description}</span>
          </a>
        );
      })}
    </div>
  </aside>
)}

<style>
  .related-section {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
  }

  .related-heading {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin: 0 0 0.75rem 0;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.5rem;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-base);
    background: var(--bg-secondary);
    text-decoration: none;
    transition: all 0.2s ease-in-out;
  }

  .related-card:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  .related-card:hover .related-title {
    color: var(--accent);
  }

  .related-type {
    font-family: var(--font-sans);
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
  }

  .related-title {
    font-family: var(--font-serif);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-heading);
    line-height: 1.3;
    transition: color 0.2s ease-in-out;
  }

  .related-desc {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    color: var(--text-muted);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
