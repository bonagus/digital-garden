---
/**
 * ContentCard — theme-aware card with improved contrast
 */
interface Props {
  title: string;
  description: string;
  href: string;
  type?: string;
  startDate?: string | Date;
  topics?: string[];
  growthStage?: 'seedling' | 'budding' | 'evergreen';
  cover?: string;
}

const { title, description, href, type = 'note', startDate, topics, growthStage, cover } = Astro.props;

const growthEmoji = {
  seedling: '🌱',
  budding: '🌿',
  evergreen: '🌳',
};

const typeLabel = {
  note: 'Note',
  notes: 'Note',
  essay: 'Essay',
  essays: 'Essay',
  project: 'Project',
  projects: 'Project',
  experiment: 'Experiment',
  experiments: 'Experiment',
};

function formatDate(date?: string | Date): string {
  if (!date) return '';
  const d = new Date(date);
  const now = new Date();
  const diff = now.getTime() - d.getTime();
  const days = Math.floor(diff / (1000 * 60 * 60 * 24));
  if (days < 1) return 'Today';
  if (days < 7) return `${days}d ago`;
  if (days < 30) return `${Math.floor(days / 7)}w ago`;
  if (days < 365) return `${Math.floor(days / 30)}mo ago`;
  return `${Math.floor(days / 365)}y ago`;
}
---

<div class="content-card">
  <a href={href} class="card-link-overlay" aria-label={title}></a>
  
  {/* Cover image di atas title */}
  {cover && (
    <div class="card-cover">
      <img src={cover} alt={title} class="cover-image" />
    </div>
  )}
  
  {growthStage && <span class="growth-icon">{growthEmoji[growthStage]}</span>}
  <div class="card-body">
    <h3 class="card-title">{title}</h3>
    <p class="card-description">{description}</p>

    {topics && topics.length > 0 && (
      <div class="card-topics">
        {topics.slice(0, 3).map((topic) => (
          <a
            href={`/topics/${encodeURIComponent(topic.toLowerCase())}`}
            class="card-topic-pill"
          >
            {topic}
          </a>
        ))}
      </div>
    )}

    <div class="card-metadata">
      <span class="card-type">{typeLabel[type as keyof typeof typeLabel] || type}</span>
      {growthStage && (
        <>
          <svg width="4" height="4" class="dot">
            <circle r="2" cx="2" cy="2" fill="currentColor" />
          </svg>
          <span class="growth-label">{growthStage}</span>
        </>
      )}
      {startDate && (
        <>
          <svg width="4" height="4" class="dot">
            <circle r="2" cx="2" cy="2" fill="currentColor" />
          </svg>
          <span class="card-date">{formatDate(startDate)}</span>
        </>
      )}
    </div>
  </div>
</div>

<style>
  .content-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 0;
    border-radius: var(--radius-base);
    border: 1px solid var(--border-color);
    background: var(--bg-secondary);
    box-shadow: var(--shadow-sm);
    transition: all 0.3s ease-in-out;
    will-change: transform, box-shadow;
    cursor: pointer;
    height: 100%;
    overflow: hidden;
  }

  .card-link-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: var(--radius-base);
  }

  .content-card:hover {
    transform: scale3d(1.02, 1.02, 1.02);
    box-shadow: var(--shadow-md);
    border-color: var(--accent);
  }

  .content-card:hover .card-title {
    color: var(--accent);
  }

  /* Cover image - full card width, flexible height */
  .card-cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-primary);
  }

  .cover-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .growth-icon {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    font-size: 1.25rem;
    z-index: 2;
    background: var(--bg-secondary);
    border-radius: 50%;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-sm);
  }

  .card-body {
    flex: 1;
    min-width: 0;
    padding: 0.875rem;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-heading);
    line-height: 1.4;
    margin: 0 0 0.375rem 0;
    transition: color 0.3s ease-in-out;
  }

  .card-description {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--text-body);
    font-weight: 400;
    margin: 0 0 0.5rem 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Topic pills inside card — must sit above the card link overlay */
  .card-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 2;
  }

  .card-topic-pill {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 400;
    color: var(--text-muted);
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 3rem;
    padding: 0.125rem 0.5rem;
    text-decoration: none;
    transition: all 0.2s ease-in-out;
  }

  .card-topic-pill:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--bg-secondary);
  }

  .card-metadata {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: capitalize;
    gap: 0;
  }

  .card-type {
    font-weight: 500;
  }

  .dot {
    margin: 0 0.4rem;
    color: var(--text-faint);
  }

  .growth-label {
    font-weight: 400;
  }

  .card-date {
    font-weight: 400;
  }
</style>
