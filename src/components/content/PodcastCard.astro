---
/**
 * PodcastCard — card for audiobook/podcast entries
 * Shows cover, author, series, play indicator
 */
interface Props {
  title: string;
  description: string;
  href: string;
  author: string;
  cover?: string;
  duration?: string;
  series?: string;
  startDate?: string | Date;
  topics?: string[];
}

const { title, description, href, author, cover, duration, series, topics } = Astro.props;
---

<div class="podcast-card">
  <a href={href} class="card-link-overlay" aria-label={title}></a>
  <div class="podcast-cover-wrapper">
    {cover ? (
      <img src={cover} alt={`Cover of ${title}`} class="podcast-cover" loading="lazy" />
    ) : (
      <div class="podcast-cover-placeholder">
        <span class="placeholder-icon">🎧</span>
      </div>
    )}
    <div class="play-indicator">
      <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor">
        <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z" />
      </svg>
    </div>
  </div>
  <div class="podcast-info">
    <div class="podcast-meta-top">
      {series && <span class="podcast-series">{series}</span>}
      {duration && <span class="podcast-duration">{duration}</span>}
    </div>
    <h3 class="podcast-title">{title}</h3>
    <p class="podcast-author">{author}</p>
    <p class="podcast-description">{description}</p>
    {topics && topics.length > 0 && (
      <div class="podcast-topics">
        {topics.slice(0, 3).map((topic) => (
          <a href={`/topics/${encodeURIComponent(topic.toLowerCase())}`} class="topic-pill">{topic}</a>
        ))}
      </div>
    )}
  </div>
</div>

<style>
  .podcast-card {
    position: relative;
    display: flex;
    gap: 1rem;
    padding: 1rem;
    border-radius: var(--radius-base);
    border: 1px solid var(--border-color);
    background: var(--bg-secondary);
    box-shadow: var(--shadow-sm);
    transition: all 0.3s ease-in-out;
    cursor: pointer;
  }

  .card-link-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: var(--radius-base);
  }

  .podcast-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent);
  }

  .podcast-card:hover .podcast-title {
    color: var(--accent);
  }

  .podcast-card:hover .play-indicator {
    opacity: 1;
    transform: scale(1);
  }

  .podcast-cover-wrapper {
    position: relative;
    flex-shrink: 0;
    width: 90px;
    height: 90px;
    border-radius: var(--radius-base);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .podcast-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .podcast-cover-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    font-size: 1.75rem;
  }

  .play-indicator {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    color: white;
    opacity: 0;
    transform: scale(0.9);
    transition: all 0.2s ease-in-out;
    border-radius: var(--radius-base);
  }

  .podcast-info {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .podcast-meta-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .podcast-series {
    font-family: var(--font-sans);
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--accent);
  }

  .podcast-duration {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--text-faint);
  }

  .podcast-title {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-heading);
    line-height: 1.3;
    margin: 0 0 0.125rem 0;
    transition: color 0.2s ease-in-out;
  }

  .podcast-author {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--text-muted);
    margin: 0 0 0.375rem 0;
  }

  .podcast-description {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--text-body);
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .podcast-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-top: 0.5rem;
    position: relative;
    z-index: 2;
  }

  .topic-pill {
    font-family: var(--font-sans);
    font-size: 0.5625rem;
    color: var(--text-muted);
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 3rem;
    padding: 0.1rem 0.4rem;
    text-decoration: none;
    transition: all 0.2s ease-in-out;
  }

  .topic-pill:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>
