---
/**
 * BookCard — card with cover image, author, rating
 * Inspired by Maggie Appleton's library layout
 */
interface Props {
  title: string;
  description: string;
  href: string;
  author: string;
  cover?: string;
  rating?: number;
  startDate?: string | Date;
  topics?: string[];
  status?: 'reading' | 'finished' | 'abandoned';
}

const { title, description, href, author, cover, rating, startDate, topics, status = 'finished' } = Astro.props;

const statusInfo: Record<string, { text: string; color: string }> = {
  reading: { text: 'Reading', color: 'var(--color-budding)' },
  finished: { text: 'Finished', color: 'var(--color-evergreen)' },
  abandoned: { text: 'Abandoned', color: 'var(--text-faint)' },
};
const si = statusInfo[status];
---

<div class="book-card">
  <a href={href} class="card-link-overlay" aria-label={title}></a>
  <div class="book-cover-wrapper">
    {cover ? (
      <img src={cover} alt={`Cover of ${title}`} class="book-cover" loading="lazy" />
    ) : (
      <div class="book-cover-placeholder">
        <span class="placeholder-icon">📖</span>
      </div>
    )}
  </div>
  <div class="book-info">
    <div class="book-meta-top">
      <span class="status-indicator" style={`--sc: ${si.color}`}>
        <span class="status-dot"></span>
        {si.text}
      </span>
      {rating && (
        <span class="rating">
          {'★'.repeat(rating)}{'☆'.repeat(5 - rating)}
        </span>
      )}
    </div>
    <h3 class="book-title">{title}</h3>
    <p class="book-author">{author}</p>
    <p class="book-description">{description}</p>
    {topics && topics.length > 0 && (
      <div class="book-topics">
        {topics.slice(0, 3).map((topic) => (
          <a href={`/topics/${encodeURIComponent(topic.toLowerCase())}`} class="topic-pill">{topic}</a>
        ))}
      </div>
    )}
  </div>
</div>

<style>
  .book-card {
    position: relative;
    display: flex;
    gap: 1rem;
    padding: 1rem;
    border-radius: var(--radius-base);
    border: 1px solid var(--border-color);
    background: var(--bg-secondary);
    box-shadow: var(--shadow-sm);
    transition: all 0.3s ease-in-out;
    cursor: pointer;
  }

  .card-link-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: var(--radius-base);
  }

  .book-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent);
  }

  .book-card:hover .book-title {
    color: var(--accent);
  }

  .book-cover-wrapper {
    flex-shrink: 0;
    width: 80px;
    height: 120px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .book-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .book-cover-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    font-size: 1.5rem;
  }

  .book-info {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .book-meta-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.375rem;
  }

  .status-indicator {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-sans);
    font-size: 0.625rem;
    font-weight: 500;
    color: var(--sc);
  }

  .status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--sc);
  }

  .rating {
    font-size: 0.6875rem;
    color: var(--accent);
    letter-spacing: -0.5px;
  }

  .book-title {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-heading);
    line-height: 1.3;
    margin: 0 0 0.125rem 0;
    transition: color 0.2s ease-in-out;
  }

  .book-author {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--text-muted);
    margin: 0 0 0.375rem 0;
  }

  .book-description {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--text-body);
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .book-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-top: 0.5rem;
    position: relative;
    z-index: 2;
  }

  .topic-pill {
    font-family: var(--font-sans);
    font-size: 0.5625rem;
    color: var(--text-muted);
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 3rem;
    padding: 0.1rem 0.4rem;
    text-decoration: none;
    transition: all 0.2s ease-in-out;
  }

  .topic-pill:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>
