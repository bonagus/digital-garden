---
/**
 * ProjectCard — richer card for project showcase
 * Shows tech stack badges, status indicator, repo/demo links
 */
interface Props {
  title: string;
  description: string;
  href: string;
  startDate?: string | Date;
  topics?: string[];
  growthStage?: 'seedling' | 'budding' | 'evergreen';
  status?: 'active' | 'completed' | 'archived' | 'paused';
  techStack?: string[];
  repoUrl?: string;
  demoUrl?: string;
  featured?: boolean;
  cover?: string;
}

const {
  title, description, href, startDate, topics,
  growthStage, status = 'active', techStack = [],
  repoUrl, demoUrl, featured = false, cover,
} = Astro.props;

const statusInfo: Record<string, { text: string; color: string }> = {
  active: { text: 'Active', color: 'var(--color-evergreen)' },
  completed: { text: 'Completed', color: 'var(--accent)' },
  archived: { text: 'Archived', color: 'var(--text-faint)' },
  paused: { text: 'Paused', color: 'var(--color-budding)' },
};

const si = statusInfo[status];

function formatDate(date?: string | Date): string {
  if (!date) return '';
  const d = new Date(date);
  const now = new Date();
  const diff = now.getTime() - d.getTime();
  const days = Math.floor(diff / (1000 * 60 * 60 * 24));
  if (days < 1) return 'Today';
  if (days < 7) return `${days}d ago`;
  if (days < 30) return `${Math.floor(days / 7)}w ago`;
  if (days < 365) return `${Math.floor(days / 30)}mo ago`;
  return `${Math.floor(days / 365)}y ago`;
}
---

<div class:list={['project-card', { featured }]}>
  <a href={href} class="card-link-overlay" aria-label={title}></a>

  {cover && (
    <div class="card-cover">
      <img src={cover} alt={title} class="cover-image" />
    </div>
  )}

  <div class="card-inner">
  <div class="card-top">
    <div class="card-top-left">
      {featured && <span class="featured-badge">★ Featured</span>}
      <span class="status-indicator" style={`--sc: ${si.color}`}>
        <span class="status-dot"></span>
        {si.text}
      </span>
    </div>
    {startDate && <span class="card-date">{formatDate(startDate)}</span>}
  </div>

  <h3 class="card-title">{title}</h3>
  <p class="card-description">{description}</p>

  {techStack.length > 0 && (
    <div class="tech-badges">
      {techStack.slice(0, 5).map((tech) => (
        <span class="tech-badge">{tech}</span>
      ))}
    </div>
  )}

  {(repoUrl || demoUrl) && (
    <div class="card-actions">
      {repoUrl && (
        <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="action-link" aria-label="Source code">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          Code
        </a>
      )}
      {demoUrl && (
        <a href={demoUrl} target="_blank" rel="noopener noreferrer" class="action-link" aria-label="Live demo">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4a.75.75 0 011.5 0v4A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h5a.75.75 0 010 1.5h-5z" clip-rule="evenodd" />
            <path fill-rule="evenodd" d="M6.194 12.753a.75.75 0 001.06.053L16.5 4.44v2.81a.75.75 0 001.5 0v-4.5a.75.75 0 00-.75-.75h-4.5a.75.75 0 000 1.5h2.553l-9.056 8.194a.75.75 0 00-.053 1.06z" clip-rule="evenodd" />
          </svg>
          Demo
        </a>
      )}
    </div>
  )}

  {topics && topics.length > 0 && (
    <div class="card-topics">
      {topics.slice(0, 3).map((topic) => (
        <a href={`/topics/${encodeURIComponent(topic.toLowerCase())}`} class="card-topic-pill">
          {topic}
        </a>
      ))}
    </div>
  )}
  </div>
</div>

<style>
  .project-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 0;
    border-radius: var(--radius-base);
    border: 1px solid var(--border-color);
    background: var(--bg-secondary);
    box-shadow: var(--shadow-sm);
    transition: all 0.3s ease-in-out;
    cursor: pointer;
    height: 100%;
    overflow: hidden;
  }

  .card-cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-primary);
  }

  .cover-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-inner {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.25rem;
  }

  .project-card.featured {
    border-color: var(--accent);
    border-width: 1.5px;
  }

  .card-link-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: var(--radius-base);
  }

  .project-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent);
  }

  .project-card:hover .card-title {
    color: var(--accent);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.625rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .card-top-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .featured-badge {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--accent);
    background: rgba(217, 119, 87, 0.1);
    border-radius: 3rem;
    padding: 0.125rem 0.5rem;
  }

  .status-indicator {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--sc);
  }

  .status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--sc);
  }

  .card-date {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    color: var(--text-faint);
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--text-heading);
    line-height: 1.35;
    margin: 0 0 0.375rem 0;
    transition: color 0.3s ease-in-out;
  }

  .card-description {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--text-body);
    font-weight: 400;
    margin: 0 0 0.75rem 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .tech-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-bottom: 0.75rem;
  }

  .tech-badge {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 400;
    color: var(--accent);
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 0.125rem 0.375rem;
  }

  .card-actions {
    display: flex;
    gap: 0.375rem;
    margin-bottom: 0.75rem;
    position: relative;
    z-index: 2;
  }

  .action-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 0.25rem 0.5rem;
    text-decoration: none;
    transition: all 0.2s ease-in-out;
  }

  .action-link:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .card-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    position: relative;
    z-index: 2;
  }

  .card-topic-pill {
    font-family: var(--font-sans);
    font-size: 0.625rem;
    font-weight: 400;
    color: var(--text-muted);
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 3rem;
    padding: 0.1rem 0.5rem;
    text-decoration: none;
    transition: all 0.2s ease-in-out;
  }

  .card-topic-pill:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>
