---
/**
 * Footer — styled like Maggie Appleton's:
 * - Two column: left (RSS + social + copyright), right (sitemap links)
 * - Warm, editorial feel
 */
const currentYear = new Date().getFullYear();

const sitemapLinks = [
  { text: 'Garden', href: '/garden' },
  { text: 'Notes', href: '/notes' },
  { text: 'Essays', href: '/essays' },
  { text: 'Projects', href: '/projects' },
  { text: 'Experiments', href: '/experiments' },
  { text: 'About', href: '/about' },
  { text: 'Contact', href: '/contact' },
];
---

<footer class="styled-footer">
  <div class="footer-content">
    <div class="footer-left">
      <h3 class="footer-heading">Stay connected</h3>
      <a href="/rss.xml" class="rss-button">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
          <path d="M5 3a1 1 0 000 2c5.523 0 10 4.477 10 10a1 1 0 102 0C17 8.373 11.627 3 5 3z" />
          <path d="M4 9a1 1 0 011-1 7 7 0 017 7 1 1 0 11-2 0 5 5 0 00-5-5 1 1 0 01-1-1z" />
          <circle cx="5" cy="15" r="2" />
        </svg>
        Subscribe via RSS
      </a>
      <div class="social-icons">
        <a href="https://github.com/bonagus" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      </div>
      <span class="copyright">© {currentYear} Bonagus</span>
    </div>

    <ul class="sitemap-list">
      {sitemapLinks.map((link) => (
        <li>
          <a href={link.href} class="sitemap-link">{link.text}</a>
        </li>
      ))}
    </ul>
  </div>
</footer>

<style>
  .styled-footer {
    padding: 3rem 0;
    border-top: 1px solid var(--color-gray-300);
    margin-top: auto;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 2fr 1fr;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer-heading {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 400;
    margin-bottom: 0.75rem;
    color: var(--color-gray-800);
  }

  .rss-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 1.2rem;
    background: none;
    border: 1px solid var(--color-tinted-cream);
    border-radius: 3rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-gray-600);
    transition: all 0.3s ease-in-out;
    text-decoration: none;
  }

  .rss-button:hover {
    color: var(--color-crimson);
    border-color: var(--color-crimson);
    box-shadow: var(--shadow-sm);
  }

  .social-icons {
    display: flex;
    align-items: center;
    margin: 1rem 0 0.5rem;
    gap: 0.75rem;
  }

  .social-icons a {
    color: var(--color-gray-400);
    transition: color 0.3s ease-in-out;
  }

  .social-icons a:hover {
    color: var(--color-bright-crimson);
  }

  .copyright {
    font-size: 0.75rem;
    font-family: var(--font-sans);
    color: var(--color-gray-500);
    display: block;
    margin-top: 0.5rem;
  }

  .sitemap-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    list-style: none;
    gap: 0.375rem 2rem;
    padding: 0;
    margin: 0;
  }

  .sitemap-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-gray-600);
    text-decoration: none;
    transition: color 0.2s ease-in-out;
  }

  .sitemap-link:hover {
    color: var(--color-crimson);
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
