---
/**
 * GardenFilters — client-side type filter buttons
 * Uses data attributes + JS to show/hide cards without page reload
 */
const types = [
  { value: 'all', label: 'All' },
  { value: 'notes', label: 'Notes' },
  { value: 'essays', label: 'Essays' },
  { value: 'books', label: 'Books' },
  { value: 'podcasts', label: 'Podcasts' },
  { value: 'projects', label: 'Projects' },
  { value: 'experiments', label: 'Experiments' },
];
---

<div class="garden-filters" id="garden-filters">
  {types.map((type) => (
    <button
      class:list={['filter-btn', { active: type.value === 'all' }]}
      data-filter={type.value}
    >
      {type.label}
    </button>
  ))}
</div>

<style>
  .garden-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .filter-btn {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--text-body);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 3rem;
    padding: 0.375rem 1rem;
    cursor: pointer;
    transition: all 0.2s ease-in-out;
  }

  .filter-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .filter-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #ffffff;
  }
</style>

<script>
  function initFilters() {
    const filtersContainer = document.getElementById('garden-filters');
    const grid = document.getElementById('content-grid');
    if (!filtersContainer || !grid) return;

    const buttons = filtersContainer.querySelectorAll('.filter-btn');
    const cards = grid.querySelectorAll('[data-type]');

    buttons.forEach((btn) => {
      const newBtn = btn.cloneNode(true) as HTMLButtonElement;
      btn.parentNode?.replaceChild(newBtn, btn);

      newBtn.addEventListener('click', () => {
        const filter = newBtn.getAttribute('data-filter');

        // Update active button
        filtersContainer.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('active'));
        newBtn.classList.add('active');

        // Filter cards
        cards.forEach((card) => {
          const cardEl = card as HTMLElement;
          if (filter === 'all' || cardEl.dataset.type === filter) {
            cardEl.style.display = '';
            cardEl.style.opacity = '0';
            requestAnimationFrame(() => {
              cardEl.style.transition = 'opacity 0.3s ease-in-out';
              cardEl.style.opacity = '1';
            });
          } else {
            cardEl.style.display = 'none';
          }
        });
      });
    });
  }

  initFilters();
  document.addEventListener('astro:page-load', initFilters);
</script>
